{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "repowise-augment",
            "timeout": 10,
            "statusMessage": "Loading repowise context..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|PowerShell|Grep|Glob|Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "repowise-augment",
            "timeout": 10,
            "statusMessage": "Checking codebase context..."
          }
        ]
      }
    ]
  }
}
